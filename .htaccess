<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /sistem-aset/

    # Forward all requests to the public folder.
    # This hides /public in the URL while allowing CodeIgniter to run.
    RewriteCond %{REQUEST_URI} !^/sistem-aset/public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
